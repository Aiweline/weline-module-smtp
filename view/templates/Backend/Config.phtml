<script>
(function() {
    'use strict';

    var senderIndex = <?= count($senders) ?>;
    var mailAccounts = <?= $mailAccountsJson ?>;
    var text = {
        noMailAccount: '<?= __("暂无匹配的自建邮箱账号") ?>',
        externalSummary: '<?= __("外部 SMTP 需手动填写下方连接信息。") ?>',
        pickMailAccount: '<?= __("请选择自建邮箱账号") ?>',
        saveFailed: '<?= __("保存失败") ?>',
        enterRecipient: '<?= __("请输入收件邮箱") ?>',
        addSender: '<?= __("请至少添加一个发件人") ?>'
    };

    function findAccount(id) {
        id = String(id || '');
        for (var i = 0; i < mailAccounts.length; i++) {
            if (String(mailAccounts[i].account_id || '') === id) {
                return mailAccounts[i];
            }
        }
        return null;
    }

    function accountLabel(account) {
        if (!account) return '';
        return account.label || ((account.email || '') + ' · ' + (account.domain_name || '') + ' · ' + (account.engine || ''));
    }

    function setTransportReadonly(card, readonly) {
        ['.smtp-host', '.smtp-port', '.smtp-username'].forEach(function(selector) {
            var input = card.querySelector(selector);
            if (input) input.readOnly = readonly;
        });
        ['.smtp-secure', '.smtp-auth'].forEach(function(selector) {
            var select = card.querySelector(selector);
            if (select) select.disabled = readonly;
        });
    }

    function fillFromAccount(card, account) {
        if (!account) return;
        var map = {
            '.smtp-host': account.smtp_host || '',
            '.smtp-port': account.smtp_port || '587',
            '.smtp-username': account.email || ''
        };
        Object.keys(map).forEach(function(selector) {
            var input = card.querySelector(selector);
            if (input) input.value = map[selector];
        });
        var secure = card.querySelector('.smtp-secure');
        if (secure) secure.value = account.smtp_secure || 'tls';
        var auth = card.querySelector('.smtp-auth');
        if (auth) auth.value = account.smtp_auth || '1';
        var hidden = card.querySelector('.smtp-mail-account-id');
        if (hidden) hidden.value = account.account_id || '';
        var search = card.querySelector('.mail-account-search');
        if (search) search.value = accountLabel(account);
        var chip = card.querySelector('.smtp-mail-selected');
        if (chip) {
            var label = accountLabel(account);
            chip.querySelector('span').textContent = label;
            chip.style.display = label ? '' : 'none';
        }
        updateSummary(card);
    }

    function updateSummary(card) {
        var summary = card.querySelector('.smtp-auto-summary');
        if (!summary) return;
        var source = (card.querySelector('.smtp-source-type') || {}).value || 'external';
        if (source !== 'mail_account') {
            summary.textContent = text.externalSummary;
            return;
        }
        var host = (card.querySelector('.smtp-host') || {}).value || '';
        var port = (card.querySelector('.smtp-port') || {}).value || '';
        var secure = (card.querySelector('.smtp-secure') || {}).value || '';
        var username = (card.querySelector('.smtp-username') || {}).value || '';
        summary.textContent = host ? (host + ':' + port + ' · ' + secure.toUpperCase() + ' · ' + username) : text.pickMailAccount;
    }

    function updateSource(card) {
        var source = (card.querySelector('.smtp-source-type') || {}).value || 'external';
        var mailRow = card.querySelector('.smtp-mail-account-row');
        var passwordHelp = card.querySelector('.smtp-mail-password-help');
        card.classList.toggle('smtp-source-mail', source === 'mail_account');
        card.classList.toggle('smtp-source-external', source !== 'mail_account');
        if (mailRow) mailRow.style.display = source === 'mail_account' ? '' : 'none';
        if (passwordHelp) passwordHelp.style.display = source === 'mail_account' ? '' : 'none';
        setTransportReadonly(card, source === 'mail_account');
        if (source === 'mail_account') {
            var account = findAccount((card.querySelector('.smtp-mail-account-id') || {}).value || '');
            if (account) fillFromAccount(card, account);
        }
        updateSummary(card);
    }

    function renderAccountResults(card, query) {
        var results = card.querySelector('.smtp-mail-results');
        if (!results) return;
        query = (query || '').toLowerCase().trim();
        var matches = mailAccounts.filter(function(account) {
            var haystack = ((account.email || '') + ' ' + (account.domain_name || '') + ' ' + (account.display_name || '') + ' ' + (account.engine || '')).toLowerCase();
            return !query || haystack.indexOf(query) !== -1;
        }).slice(0, 8);
        if (matches.length === 0) {
            results.innerHTML = '<div class="p-2 text-muted small">' + text.noMailAccount + '</div>';
        } else {
            results.innerHTML = matches.map(function(account) {
                return '<button type="button" class="smtp-mail-option" data-account-id="' + String(account.account_id || '') + '">' +
                    '<div class="fw-semibold">' + escapeHtml(account.email || '') + '</div>' +
                    '<div class="small text-muted">' + escapeHtml((account.domain_name || '') + ' · ' + (account.is_fake ? 'fake' : (account.engine || ''))) + '</div>' +
                    '</button>';
            }).join('');
        }
        results.classList.add('is-open');
    }

    function escapeHtml(value) {
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function requestJson(url, options) {
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.request === 'function') {
            return window.Weline.Api.request(url, options);
        }

        if (typeof window.fetch === 'function') {
            return window.fetch(url, options).then(function(res) {
                return res.json();
            });
        }

        return new Promise(function(resolve, reject) {
            var xhr = new XMLHttpRequest();
            xhr.open(options.method || 'GET', url, true);
            var headers = options.headers || {};
            Object.keys(headers).forEach(function(name) {
                xhr.setRequestHeader(name, headers[name]);
            });
            xhr.onload = function() {
                try {
                    resolve(JSON.parse(xhr.responseText || '{}'));
                } catch (e) {
                    reject(e);
                }
            };
            xhr.onerror = reject;
            xhr.send(options.body || null);
        });
    }

    function collectSenders() {
        var list = [];
        document.querySelectorAll('.smtp-sender-card').forEach(function(card) {
            var code = (card.querySelector('.smtp-code') && card.querySelector('.smtp-code').value.trim()) || '';
            if (!code) return;
            var pwd = card.querySelector('.smtp-password');
            var source = (card.querySelector('.smtp-source-type') && card.querySelector('.smtp-source-type').value) || 'external';
            var account = source === 'mail_account' ? findAccount((card.querySelector('.smtp-mail-account-id') || {}).value || '') : null;
            list.push({
                code: code,
                name: (card.querySelector('.smtp-name') && card.querySelector('.smtp-name').value) || code,
                source_type: source,
                mail_account_id: account ? String(account.account_id || '') : '',
                mail_account_email: account ? (account.email || '') : '',
                mail_domain_id: account ? String(account.domain_id || '') : '',
                mail_domain_name: account ? (account.domain_name || '') : '',
                mail_engine: account ? (account.engine || '') : '',
                mail_is_fake: account && account.is_fake ? '1' : '0',
                smtp_host: (card.querySelector('.smtp-host') && card.querySelector('.smtp-host').value) || '',
                smtp_port: (card.querySelector('.smtp-port') && card.querySelector('.smtp-port').value) || '465',
                smtp_secure: (card.querySelector('.smtp-secure') && card.querySelector('.smtp-secure').value) || 'ssl',
                smtp_auth: (card.querySelector('.smtp-auth') && card.querySelector('.smtp-auth').value) || '1',
                smtp_username: (card.querySelector('.smtp-username') && card.querySelector('.smtp-username').value) || '',
                smtp_password: (pwd && pwd.value) ? pwd.value : (card.getAttribute('data-pwd') || ''),
                smtp_test_address: ''
            });
        });
        return list;
    }

    function collectContacts() {
        var obj = {};
        document.querySelectorAll('.smtp-sender-card').forEach(function(card) {
            var code = (card.querySelector('.smtp-code') && card.querySelector('.smtp-code').value) || '';
            var contact = (card.querySelector('.smtp-contact') && card.querySelector('.smtp-contact').value) || '';
            if (code) obj[code] = contact;
        });
        return obj;
    }

    function addSenderCard() {
        var tpl = document.getElementById('smtpSenderCardTemplate');
        var node = tpl.content.firstElementChild.cloneNode(true);
        node.setAttribute('data-index', String(senderIndex));
        document.getElementById('sendersList').appendChild(node);
        senderIndex++;
        updateSource(node);
    }

    document.getElementById('btnAddSender').addEventListener('click', addSenderCard);

    document.getElementById('sendersList').addEventListener('change', function(e) {
        if (e.target.closest('.smtp-source-type')) {
            updateSource(e.target.closest('.smtp-sender-card'));
        }
    });

    document.getElementById('sendersList').addEventListener('input', function(e) {
        var card = e.target.closest('.smtp-sender-card');
        if (!card) return;
        if (e.target.closest('.mail-account-search')) {
            renderAccountResults(card, e.target.value);
            return;
        }
        if (e.target.closest('.smtp-host') || e.target.closest('.smtp-port') || e.target.closest('.smtp-username')) {
            updateSummary(card);
        }
    });

    document.getElementById('sendersList').addEventListener('focusin', function(e) {
        if (e.target.closest('.mail-account-search')) {
            renderAccountResults(e.target.closest('.smtp-sender-card'), e.target.value);
        }
    });

    document.addEventListener('click', function(e) {
        var option = e.target.closest('.smtp-mail-option');
        if (option) {
            var card = option.closest('.smtp-sender-card');
            var account = findAccount(option.getAttribute('data-account-id'));
            if (card && account) {
                fillFromAccount(card, account);
                var results = card.querySelector('.smtp-mail-results');
                if (results) results.classList.remove('is-open');
            }
            return;
        }
        if (!e.target.closest('.smtp-mail-picker')) {
            document.querySelectorAll('.smtp-mail-results.is-open').forEach(function(node) {
                node.classList.remove('is-open');
            });
        }
    });

    document.getElementById('sendersList').addEventListener('click', function(e) {
        var rm = e.target.closest('.btn-remove-sender');
        if (rm) {
            var card = rm.closest('.smtp-sender-card');
            if (!card) return;
            if (document.querySelectorAll('.smtp-sender-card').length > 1) {
                card.remove();
                return;
            }
            var removeMessage = '<?= __("确定删除最后一个发件人吗？删除后仍可重新添加。") ?>';
            if (typeof BackendConfirm !== 'undefined' && BackendConfirm.show) {
                BackendConfirm.show(removeMessage).then(function(confirmed) {
                    if (confirmed) card.remove();
                });
            } else {
                card.remove();
            }
        }
    });

    var testModal = null;
    document.getElementById('sendersList').addEventListener('click', function(e) {
        var btn = e.target.closest('.btn-test-sender');
        if (!btn) return;
        var card = btn.closest('.smtp-sender-card');
        var code = btn.getAttribute('data-code') || (card && card.querySelector('.smtp-code') && card.querySelector('.smtp-code').value);
        document.getElementById('testSenderCode').value = code || '';
        document.getElementById('testEmailTo').value = '';
        if (typeof bootstrap !== 'undefined') {
            if (!testModal) testModal = new bootstrap.Modal(document.getElementById('testEmailModal'));
            testModal.show();
        }
    });

    document.getElementById('btnDoTest').addEventListener('click', function() {
        var code = document.getElementById('testSenderCode').value;
        var to = document.getElementById('testEmailTo').value.trim();
        if (!to) {
            if (typeof BackendToast !== 'undefined') BackendToast.error(text.enterRecipient);
            return;
        }
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '<?= $this->getBackendUrl('smtp/backend/config/posttest') ?>';
        var c = document.createElement('input'); c.type = 'hidden'; c.name = 'smtp_test_address'; c.value = to;
        form.appendChild(c);
        if (code) {
            var sc = document.createElement('input'); sc.type = 'hidden'; sc.name = 'sender_code'; sc.value = code;
            form.appendChild(sc);
        }
        document.body.appendChild(form);
        form.submit();
    });

    var savingSenders = false;
    function saveSenders(e) {
        if (e) e.preventDefault();
        if (savingSenders) return;
        var senders = collectSenders();
        var contacts = collectContacts();
        if (senders.length === 0) {
            if (typeof BackendToast !== 'undefined') BackendToast.error(text.addSender);
            return;
        }
        var needsMailAccount = senders.some(function(sender) {
            return sender.source_type === 'mail_account' && !sender.mail_account_id;
        });
        if (needsMailAccount) {
            if (typeof BackendToast !== 'undefined') BackendToast.error(text.pickMailAccount);
            return;
        }
        savingSenders = true;
        var url = '<?= $this->getBackendUrl('smtp/backend/config/saveSenders') ?>';
        var body = JSON.stringify({
            senders: senders,
            sender_contacts: contacts,
            smtp_senders_json: JSON.stringify(senders),
            smtp_sender_contacts_json: JSON.stringify(contacts)
        });
        requestJson(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })
            .then(function(res) {
                var d = (res && res.data) !== undefined ? res.data : res;
                if (d.success) {
                    if (typeof BackendToast !== 'undefined') BackendToast.success(d.message);
                    setTimeout(function() { window.location.reload(); }, 800);
                } else {
                    if (typeof BackendToast !== 'undefined') BackendToast.error(d.message || text.saveFailed);
                    savingSenders = false;
                }
            })
            .catch(function() {
                if (typeof BackendToast !== 'undefined') BackendToast.error(text.saveFailed);
                savingSenders = false;
            });
    }

    document.getElementById('smtpSendersForm').addEventListener('submit', saveSenders);
    var saveButton = document.querySelector('#smtpSendersForm button[type="submit"]');
    if (saveButton) saveButton.addEventListener('click', saveSenders);

    document.querySelectorAll('.smtp-sender-card').forEach(updateSource);
    if (document.querySelectorAll('.smtp-sender-card').length === 0) {
        addSenderCard();
    }
})();
</script>
