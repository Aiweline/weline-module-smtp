<?php
/**
 * SMTP 发件人配置（多发件人 + 默认联系人 + 自建邮局账号）
 * @var \Weline\Framework\View\Template $this
 * @var array $senders 发件人列表 [{ code, name, source_type, smtp_host, ... }]
 * @var array $mail_accounts 自建邮箱账号候选 [{ account_id, email, ... }]
 * @var array $sender_contacts 发件人 code => 默认收件邮箱
 * @var array $legacy 旧版单配置（兼容）
 */
$senders = $senders ?? [];
$mail_accounts = $mail_accounts ?? [];
$sender_contacts = $sender_contacts ?? [];
$legacy = $legacy ?? [];
$normalizeSecure = static function ($value, $port = '465'): string {
    $value = strtolower(trim((string)$value));
    if (in_array($value, ['ssl', 'smtps', '1', 'true', 'on', 'yes', '465'], true)) {
        return 'ssl';
    }
    if (in_array($value, ['tls', 'starttls', '2', '587'], true)) {
        return 'tls';
    }
    if (in_array($value, ['none', 'off', 'false'], true)) {
        return 'none';
    }
    if ($value === '0') {
        return (string)$port === '587' ? 'tls' : 'none';
    }
    return (string)$port === '587' ? 'tls' : 'ssl';
};
$normalizeAuth = static function ($value): string {
    return in_array(strtolower(trim((string)$value)), ['0', 'false', 'off', 'no'], true) ? '0' : '1';
};
$findMailAccount = static function ($accountId) use ($mail_accounts): ?array {
    $accountId = (int)$accountId;
    if ($accountId <= 0) {
        return null;
    }
    foreach ($mail_accounts as $account) {
        if ((int)($account['account_id'] ?? 0) === $accountId) {
            return $account;
        }
    }
    return null;
};
$mailAccountsJson = json_encode($mail_accounts, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT);
$mailAccountsJson = is_string($mailAccountsJson) && $mailAccountsJson !== '' ? $mailAccountsJson : '[]';
?>

